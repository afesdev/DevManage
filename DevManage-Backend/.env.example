# Puerto HTTP (Render suele inyectar PORT)
PORT=3000

# Orígenes CORS permitidos (frontend Vite local y producción), separados por coma
# CORS_ORIGIN=http://localhost:5173,https://tu-app.vercel.app

# URL del frontend (redirección tras OAuth de GitHub)
# FRONTEND_URL=http://localhost:5173

# SQL Server
DB_SERVER=localhost
# Puerto (CloudClusters / Azure suelen usar 1433)
# DB_PORT=1433
# Ms antes de fallar la conexión (por defecto 30000; el driver antes usaba 15000)
# DB_CONNECT_TIMEOUT_MS=30000
DB_NAME=devmanage
DB_USER=
DB_PASSWORD=

# Si ves ETIMEOUT hacia un SQL en la nube: en el panel del proveedor permite tu IP pública
# (firewall / whitelist). Comprueba que tu red no bloquee salida TCP al puerto configurado.

# Cifrado TLS hacia SQL Azure / recomendado true en producción
DB_ENCRYPT=true

# Solo desarrollo local con certificado autofirmado (no usar en producción)
DB_TRUST_SERVER_CERTIFICATE=false

# JWT para autenticación del backend (obligatorio en producción)
JWT_SECRET=coloca_un_secreto_fuerte
# Duración del access token (ej: 15m, 1h, 7d)
JWT_EXPIRES_IN=1h

# GitHub — webhook, API y OAuth para usuarios
# Secreto para validar firma X-Hub-Signature-256 del webhook
GITHUB_WEBHOOK_SECRET=coloca_un_secreto_webhook_fuerte
# PAT del servidor (opcional). El usuario puede usar "Conectar GitHub" (OAuth) sin esto.
# GITHUB_TOKEN=

# OAuth App en https://github.com/settings/developers — Authorization callback URL debe ser:
#   {API_PUBLIC}/auth/github/callback   ej. http://localhost:3000/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/auth/github/callback
